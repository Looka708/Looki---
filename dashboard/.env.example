# ── KOYEB DEPLOYMENT ENVIRONMENT VARIABLES ──
# Set these in the Koyeb dashboard (Environment Variables section)

# NEXTAUTH
NEXTAUTH_URL="https://your-app-name.koyeb.app"
NEXTAUTH_SECRET="your-32-character-secret-key"

# DISCORD (Create at https://discord.com/developers/applications)
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"

# DATABASE (If using Supabase)
SUPABASE_URL="your-supabase-project-url"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# OPTIONAL
PORT=8080
NODE_ENV=production