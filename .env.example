# Looki Bot Configuration Example
DISCORD_TOKEN=your_discord_bot_token_here
BOT_ID=your_discord_application_id
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Spotify
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Database
DATABASE_URL="postgres://user:password@host:port/database"

# Lavalink Integration (Shoukaku)
# The bot uses every configured node by default. Set LAVALINK_NODE_NAMES
# to a comma-separated list such as "Primary,Lexis" if you want to limit it.
LAVALINK_NODE_NAMES=

LAVALINK_URL=localhost:2333
LAVALINK_PWD=youshallnotpass
LAVALINK_SECURE=false

LAVALINK_LEXIS_URL=
LAVALINK_LEXIS_PWD=
LAVALINK_LEXIS_SECURE=true

LAVALINK_JIRAYU_URL=
LAVALINK_JIRAYU_PWD=
LAVALINK_JIRAYU_SECURE=true

LAVALINK_SERENETIA_URL=
LAVALINK_SERENETIA_PWD=
LAVALINK_SERENETIA_SECURE=true

LAVALINK_G3V_URL=
LAVALINK_G3V_PWD=
LAVALINK_G3V_SECURE=true

# Keep-Alive
PORT=8080
SELF_URL=https://your-bot-url.koyeb.app
